pkgname=mullvad-tailscale-split-tunnel
# Version/rel is updated by CI, do not edit manually
pkgver=1.0.2
pkgrel=1
pkgdesc='Split tunneling config for Mullvad VPN and Tailscale'
arch=('x86_64')
url="https://github.com/hypergonial/arch_repo/tree/main/mullvad-tailscale-split-tunnel"
license=('MIT')
depends=(systemd
         nftables
         iptables
         mullvad-vpn
         tailscale)
makedepends=(git)
source=("mullvad-ts.rules"
        "mullvad-ts-cleanup.rules"
        "ts-service-ext.conf")
sha256sums=('b04551ff7ca9e07e00eaaf7247d0b8e3ada24ccee1393be9ea883bdece9473ba'
            '3b85c5ae584baea6b4c77e9c405df779863d61c9e7caded2961a2afd20459580'
            'c17a6d3f51d5f254e1dd30aaaa2f98d25fe3c5bd1efaf8e4c486f850260de6cb')

package() {
	# Copy nft.rules to the package directory
    install -Dm744 "${srcdir}/mullvad-ts.rules" "${pkgdir}/usr/share/${pkgname}/mullvad-ts.rules"
    install -Dm744 "${srcdir}/mullvad-ts-cleanup.rules" "${pkgdir}/usr/share/${pkgname}/mullvad-ts-cleanup.rules"
    install -Dm644 "${srcdir}/ts-service-ext.conf" "${pkgdir}/usr/lib/systemd/system/tailscaled.service.d/10-${pkgname}.conf"
}
